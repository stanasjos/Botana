<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Botana.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{AppThemeBinding Light={StaticResource LightBgColor},
                                     Dark={StaticResource DarkBgColor}}">

    <!-- карточка по центру, фон приложения остаётся как есть -->
    <Grid Padding="24">
        <Border
            Style="{StaticResource CardStyle}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="560"
            MaximumWidthRequest="600">

            <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,Auto">

                <!-- Заголовок -->
                <Label Grid.Row="0" Grid.Column="0"
                       Text="Create account"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource LightTextPrimary},
                                                Dark={StaticResource DarkTextPrimary}}"/>

                <!-- Крестик внутри карточки -->
                <ImageButton Grid.Row="0" Grid.Column="1"
                             Source="{AppThemeBinding Light=close_light.png, Dark=close_dark.png}"
                             WidthRequest="32" HeightRequest="32" Padding="6"
                             BackgroundColor="{AppThemeBinding Light={StaticResource IconBgLight},
                                                              Dark={StaticResource IconBgDark}}"
                             Aspect="AspectFit"
                             Clicked="OnCloseClicked"/>

                <!-- Форма -->
                <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2"
                                     Spacing="14" Margin="0,12,0,0">

                    <!-- Name -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Name" Style="{StaticResource SecondaryText}" />
                        <Entry x:Name="NameEntry"
                               Style="{StaticResource SolidEntry}"
                               Placeholder="Your name"/>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email" Style="{StaticResource SecondaryText}" />
                        <Entry x:Name="EmailEntry"
                               Style="{StaticResource SolidEntry}"
                               Keyboard="Email"
                               Placeholder="you@company.com"/>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password" Style="{StaticResource SecondaryText}" />
                        <Entry x:Name="PasswordEntry"
                               Style="{StaticResource SolidEntry}"
                               IsPassword="True"
                               Placeholder="••••••••"/>
                    </VerticalStackLayout>

                    <!-- Confirm -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Confirm password" Style="{StaticResource SecondaryText}" />
                        <Entry x:Name="ConfirmEntry"
                               Style="{StaticResource SolidEntry}"
                               IsPassword="True"
                               Placeholder="••••••••"/>
                    </VerticalStackLayout>

                    <!-- Terms -->
                    <HorizontalStackLayout Spacing="8">
                        <CheckBox x:Name="TermsCheck"/>
                        <Label Text="I agree to Terms &amp; Privacy"
                               VerticalTextAlignment="Center"
                               Style="{StaticResource SecondaryText}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTermsTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Submit -->
                    <Button Text="Create account"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnSignUpClicked"/>

                    <!-- Link to Sign in -->
                    <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Have an account?" Style="{StaticResource SecondaryText}" />
                        <Label Text="Sign in"
                               TextDecorations="Underline"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGoLoginTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>