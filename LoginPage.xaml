<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Botana.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{AppThemeBinding Light={StaticResource LightBgColor},
                                     Dark={StaticResource DarkBgColor}}">

    <!-- Центруем карточку, фон страницы НЕ трогаем -->
    <Grid Padding="24">
        <Border
            Style="{StaticResource CardStyle}"          
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="520"
            MaximumWidthRequest="560">

            <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,Auto">

                <!-- Заголовок -->
                <Label Grid.Row="0" Grid.Column="0"
                       Text="Sign in"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource LightTextPrimary},
                                                Dark={StaticResource DarkTextPrimary}}"/>

                <!-- Крестик внутри карточки -->
                <ImageButton Grid.Row="0" Grid.Column="1"
                             Source="{AppThemeBinding Light=close_light.png, Dark=close_dark.png}"
                             WidthRequest="32" HeightRequest="32" Padding="6"
                             BackgroundColor="{AppThemeBinding Light={StaticResource IconBgLight}, Dark={StaticResource IconBgDark}}"
                             Aspect="AspectFit"
                             Clicked="OnCloseClicked"/>

                <!-- Форма -->
                <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="14" Margin="0,12,0,0">

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email" Style="{StaticResource SecondaryText}" />
                        <Entry x:Name="EmailEntry"
                               Style="{StaticResource SolidEntry}"
                               Keyboard="Email"
                               Placeholder="you@company.com"/>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password" Style="{StaticResource SecondaryText}" />
                        <Entry x:Name="PasswordEntry"
                               Style="{StaticResource SolidEntry}"
                               IsPassword="True"
                               Placeholder="••••••••"/>
                    </VerticalStackLayout>

                    <!-- Кнопка -->
                    <Button Text="Sign in"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnSignInClicked"/>

                    <!-- Ссылка на регистрацию -->
                    <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="No account?" Style="{StaticResource SecondaryText}"/>
                        <Label Text="Create one"
                               TextDecorations="Underline"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGoRegisterTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>