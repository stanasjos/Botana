<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Карточки (фон, запасные ключи) -->
    <Color x:Key="LightCardBg">#F7F7F7</Color>
    <Color x:Key="DarkCardBg">#111111</Color>

    <!-- Light theme -->
    <Color x:Key="LightBgColor">#FFFFFF</Color>
    <Color x:Key="LightSurfaceColor">#F7F7F7</Color>
    <Color x:Key="LightCardColor">#FFFFFF</Color>
    <Color x:Key="LightCardStroke">#E3E3E3</Color>
    <Color x:Key="LightTextPrimary">#111111</Color>
    <Color x:Key="LightTextSecondary">#444A57</Color>

    <!-- Dark theme -->
    <Color x:Key="DarkBgColor">#0B0F1A</Color>
    <Color x:Key="DarkSurfaceColor">#111622</Color>
    <Color x:Key="DarkCardColor">#161C2A</Color>
    <Color x:Key="DarkCardStroke">#232C3F</Color>
    <Color x:Key="DarkTextPrimary">#FFFFFF</Color>
    <Color x:Key="DarkTextSecondary">#C7CFDC</Color>

    <!-- Акцентные -->
    <Color x:Key="AccentBlue">#4AA1FF</Color>
    <Color x:Key="AccentGreen">#35D07F</Color>
    <Color x:Key="AccentPink">#FF4AA1</Color>

   
    <!-- Brand: calm green -->
    <Color x:Key="Primary">#6FCF97</Color>
    <!-- мягкий травяной -->
    <Color x:Key="PrimaryLight">#A9E3C3</Color>
    <!-- светлая для hover/свечения -->
    <Color x:Key="PrimaryDark">#2F855A</Color>
    <!-- нажатие -->
    <Color x:Key="PrimaryDarkText">#242424</Color>

    
    <!-- полупрозрачная подложка при клике -->
    <Color x:Key="PrimaryTint">#146FCF97</Color>
    <!-- ~8% непрозрачности -->

    <!-- стеклянный контур -->
    <Color x:Key="GlassBorderLight">#33000000</Color>
    <Color x:Key="GlassBorderDark">#33FFFFFF</Color>

    <!-- кисть для свечения -->
    <SolidColorBrush x:Key="GreenGlowBrush" Color="{StaticResource PrimaryLight}" />


    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880E5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <!-- Общие -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Кисти -->
    <SolidColorBrush x:Key="PrimaryBrush"   Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="GlowBrush"      Color="{StaticResource PrimaryLight}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush"  Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush"     Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush"     Color="{StaticResource Black}" />

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />

    <!-- Подложка под иконку профиля -->
    <Color x:Key="IconBgLight">#1A000000</Color>
    <Color x:Key="IconBgDark">#1AFFFFFF</Color>

</ResourceDictionary>